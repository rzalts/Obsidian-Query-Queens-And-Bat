<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Show Order</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/showorderadd" method="POST">
    <div class="form-group"><label>Show ID</label><input type="number" name="show_id" value="<%= show_id || '' %>" placeholder="Enter Show ID" required/></div>
    <div class="form-group"><label>Look ID</label><input type="number" name="look_id" placeholder="Enter Look ID" required/></div>
    <div class="form-group">
      <label>Sequence Number <span style="font-size:12px;color:#888">(next suggested: <%= suggested_seq %>)</span></label>
      <input type="number" name="sequence_number" value="<%= suggested_seq %>" placeholder="Enter Sequence Number" required/>
    </div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add to Show Order</button>
  </form>
</div>
</body></html>
