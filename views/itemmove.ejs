<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Move Item</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/itemmove" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Item ID</label><input type="number" name="item_id" placeholder="Enter Item ID to move" required/></div>
    <div class="form-group"><label>New Location ID</label><input type="number" name="location_id" placeholder="Enter destination Location ID" required/></div>
    <div class="form-group"><label>Collection ID <span style="font-size:12px;color:#888">(item must belong to this collection)</span></label><input type="number" name="collection_id" placeholder="Enter Collection ID" required/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">&#8594; Move Item</button>
    <a href="/item<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-outline" style="width:100%;margin-top:10px;text-align:center;display:block">&#8592; Cancel</a>
  </form>
</div>
<img class="page-wm" src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=500&q=60" alt=""/>
</body></html>
