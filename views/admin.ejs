<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="admin-layout">

  <!-- LEFT SIDEBAR: navigation buttons -->
  <aside class="admin-sidebar">
    <p class="sidebar-label">Navigate</p>
    <a href="/myshows"    class="sidebar-btn">&#127910; Shows</a>
    <a href="/collection" class="sidebar-btn">&#128218; Collections</a>
    <a href="/look"       class="sidebar-btn">&#128084; Looks</a>
    <a href="/item"       class="sidebar-btn">&#128092; Items</a>
    <a href="/model"      class="sidebar-btn">&#128100; Models</a>
    <a href="/fitting"    class="sidebar-btn">&#128203; Fittings</a>
    <a href="/alteration" class="sidebar-btn">&#9986;&#65039; Alterations</a>
    <a href="/location"   class="sidebar-btn">&#128205; Locations</a>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="admin-main">
    <a href="/admin" style="text-decoration:none;color:inherit;"><h1 class="admin-title">OBSIDIAN</h1></a>
    <h2 class="admin-subtitle">Developer Dashboard</h2>
    <%- include('partials/flash') %>

    <!-- Stat cards -->
    <div class="stat-grid">
      <a href="/myshows" class="stat-card">
        <span class="stat-number"><%= stats.total_shows %></span>
        <span class="stat-label">Shows</span>
      </a>
      <a href="/collection" class="stat-card">
        <span class="stat-number"><%= stats.total_collections %></span>
        <span class="stat-label">Collections</span>
      </a>
      <a href="/look" class="stat-card">
        <span class="stat-number"><%= stats.total_looks %></span>
        <span class="stat-label">Looks</span>
      </a>
      <a href="/item" class="stat-card">
        <span class="stat-number"><%= stats.total_items %></span>
        <span class="stat-label">Items</span>
      </a>
      <a href="/model" class="stat-card">
        <span class="stat-number"><%= stats.total_models %></span>
        <span class="stat-label">Models</span>
      </a>
      <a href="/fitting" class="stat-card">
        <span class="stat-number"><%= stats.total_fittings %></span>
        <span class="stat-label">Fittings</span>
      </a>
      <a href="/alteration" class="stat-card">
        <span class="stat-number"><%= stats.total_alterations %></span>
        <span class="stat-label">Alterations</span>
      </a>
      <a href="/location" class="stat-card">
        <span class="stat-number"><%= stats.total_locations %></span>
        <span class="stat-label">Locations</span>
      </a>
    </div>

    <!-- Per-show breakdown table -->
    <h3 class="section-heading">SHOWS BREAKDOWN</h3>
    <div class="table-wrapper" style="margin-bottom:36px;">
      <table>
        <thead>
          <tr>
            <th>Show</th>
            <th>Date</th>
            <th>Venue</th>
            <th>Coordinator</th>
            <th>Collection</th>
            <th>Looks</th>
            <th>Items</th>
            <th>Models</th>
            <th>Fittings</th>
            <th>Alterations</th>
            <th>Show Order</th>
            <th>Locations</th>
          </tr>
        </thead>
        <tbody>
          <% showBreakdown.forEach(s => { %>
            <tr>
              <td><a href="/mymenu/<%= s.show_id %>" style="font-weight:600;color:#111;text-decoration:none;"><%= s.show_name %></a></td>
              <td><%= s.show_date ? new Date(s.show_date).toLocaleDateString() : '—' %></td>
              <td><%= s.venue || '—' %></td>
              <td><%= s.coordinator_name || '—' %></td>
              <td><%= s.collection_name || '—' %></td>
              <td style="text-align:center"><a href="/look?show_id=<%= s.show_id %>" class="count-link"><%= s.look_count %></a></td>
              <td style="text-align:center"><a href="/item?show_id=<%= s.show_id %>" class="count-link"><%= s.item_count %></a></td>
              <td style="text-align:center"><a href="/model?show_id=<%= s.show_id %>" class="count-link"><%= s.model_count %></a></td>
              <td style="text-align:center"><a href="/fitting?show_id=<%= s.show_id %>" class="count-link"><%= s.fitting_count %></a></td>
              <td style="text-align:center"><a href="/alteration?show_id=<%= s.show_id %>" class="count-link"><%= s.alteration_count %></a></td>
              <td style="text-align:center"><a href="/showorder?show_id=<%= s.show_id %>" class="count-link"><%= s.order_count %></a></td>
              <td style="text-align:center"><a href="/location?show_id=<%= s.show_id %>" class="count-link"><%= s.location_count %></a></td>
            </tr>
          <% }) %>
          <% if (!showBreakdown.length) { %>
            <tr><td colspan="12" style="text-align:center;color:#888">No shows yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- All coordinators table -->
    <h3 class="section-heading">ALL COORDINATORS</h3>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Shows</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% coordinators.forEach(c => { %>
            <tr>
              <td><%= c.user_id %></td>
              <td><%= c.first_name %> <%= c.last_name %></td>
              <td><%= c.email %></td>
              <td><%= c.phone_number || '—' %></td>
              <td>
                <span style="
                  background:<%= c.reg_role === 'developer' ? '#111' : '#e8e8e8' %>;
                  color:<%= c.reg_role === 'developer' ? '#fff' : '#333' %>;
                  padding:3px 10px;border-radius:12px;font-size:12px;font-weight:500;">
                  <%= c.reg_role || 'coordinator' %>
                </span>
              </td>
              <td style="font-weight:600;"><%= c.show_count %></td>
              <td>
                <% if (c.reg_role !== 'developer') { %>
                  <form action="/admin/deletecoordinator" method="POST" style="margin:0;" onsubmit="return confirm('Delete <%= c.first_name %> <%= c.last_name %>? This cannot be undone.')">
                    <input type="hidden" name="user_id" value="<%= c.user_id %>"/>
                    <button type="submit" style="background:#c0392b;color:#fff;border:none;padding:4px 12px;border-radius:6px;font-size:12px;cursor:pointer;">Delete</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (!coordinators.length) { %>
            <tr><td colspan="7" style="text-align:center;color:#888">No coordinators found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
/* ── Layout ── */
.admin-layout {
  display: flex;
  min-height: calc(100vh - 52px);
}

/* ── Sidebar ── */
.admin-sidebar {
  width: 200px;
  min-width: 200px;
  background: #111;
  padding: 28px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.sidebar-label {
  font-size: 10px;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 4px;
  padding-left: 4px;
}
.sidebar-btn {
  display: block;
  padding: 10px 14px;
  border-radius: 8px;
  background: transparent;
  color: #ccc;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: background .15s, color .15s;
}
.sidebar-btn:hover {
  background: #222;
  color: #fff;
}

/* ── Main area ── */
.admin-main {
  flex: 1;
  padding: 36px 40px;
  overflow-y: auto;
}
.admin-title {
  text-align: center;
  font-size: 36px;
  font-weight: 800;
  letter-spacing: 4px;
  margin-bottom: 4px;
}
.admin-subtitle {
  text-align: center;
  font-size: 13px;
  color: #888;
  font-weight: 400;
  letter-spacing: 1px;
  margin-bottom: 32px;
}
.section-heading {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .8px;
  margin: 28px 0 12px;
  color: #444;
}

/* ── Stat grid ── */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 14px;
  margin-bottom: 8px;
}
.stat-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  box-shadow: 0 1px 4px rgba(0,0,0,.08);
  text-decoration: none;
  color: inherit;
  transition: transform .15s, box-shadow .15s;
}
.stat-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 18px rgba(0,0,0,.13);
}
.stat-number {
  font-size: 30px;
  font-weight: 700;
  color: #111;
}
.stat-label {
  font-size: 11px;
  color: #888;
  text-transform: uppercase;
  letter-spacing: .6px;
}
.count-link {
  color: #111;
  font-weight: 600;
  text-decoration: none;
}
.count-link:hover {
  text-decoration: underline;
  color: #555;
}
</style>

</body></html>
