<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">My Shows</h2>
  <%- include('partials/flash') %>
  <div class="shows-grid">
    <% shows.forEach(show => { %>
      <a href="/mymenu/<%= show.show_id %>" class="show-card">
        <div class="show-name-box" style="background:<%= show.card_color || '#111111' %>;color:<%= (show.card_color || '#111111') === '#F5F0E8' ? '#333' : '#fff' %>"><%= show.show_name %></div>
        <% if (isAdmin && show.coordinator_name) { %>
          <span style="font-size:11px;color:#888;margin-top:2px;"><%= show.coordinator_name %></span>
        <% } %>
      </a>
    <% }) %>
    <% if (!shows.length) { %>
      <p style="grid-column:1/-1;text-align:center;color:#888;font-size:14px">No shows yet. Add your first show!</p>
    <% } %>
  </div>
  <div class="btn-group">
    <a href="/myshowsregistration" class="btn btn-dark">+ Add Show</a>
    <a href="/myshowsdelete" class="btn btn-dark">- Delete Show</a>
    <% if (isAdmin) { %><a href="/admin" class="btn btn-outline">&#8592; Dashboard</a><% } %>
  </div>
</div>
</body></html>
