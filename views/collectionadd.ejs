<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Collection</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/collectionadd" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Collection Name</label><input type="text" name="collection_name" placeholder="Enter Collection Name" required/></div>
    <div class="form-group"><label>Brand</label><input type="text" name="brand" placeholder="Enter Brand Name" required/></div>
    <div class="form-group"><label>Season</label><input type="text" name="season" placeholder="Enter Season"/></div>
    <div class="form-group"><label>Year</label><input type="number" name="collection_year" placeholder="Enter Year"/></div>
    <div class="form-group"><label>Status</label><input type="text" name="collection_status" placeholder="e.g. Finished / Not Finished"/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add Collection</button>
  </form>
</div>
<img class="page-wm" src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=500&q=60" alt=""/>
</body></html>
