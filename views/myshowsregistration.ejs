<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">New Show</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/myshowsregistration" method="POST" id="showForm">

    <p style="font-size:12px;color:#888;margin-bottom:16px;letter-spacing:.4px;">SHOW DETAILS</p>

    <div class="form-group">
      <label>Show Name</label>
      <input type="text" name="show_name" placeholder="Enter Show Name" required/>
    </div>

    <!-- Date dropdowns -->
    <div class="form-group">
      <label>Show Date</label>
      <div style="display:flex;gap:8px;">
        <select id="sel_month" style="flex:2;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;" required>
          <option value="" disabled selected>Month</option>
          <option value="01">January</option><option value="02">February</option>
          <option value="03">March</option><option value="04">April</option>
          <option value="05">May</option><option value="06">June</option>
          <option value="07">July</option><option value="08">August</option>
          <option value="09">September</option><option value="10">October</option>
          <option value="11">November</option><option value="12">December</option>
        </select>
        <select id="sel_day" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;" required>
          <option value="" disabled selected>Day</option>
          <% for(let d=1;d<=31;d++){ %><option value="<%= String(d).padStart(2,'0') %>"><%= d %></option><% } %>
        </select>
        <select id="sel_year" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;" required>
          <option value="" disabled selected>Year</option>
        </select>
      </div>
      <input type="hidden" name="show_date" id="show_date"/>
    </div>

    <div class="form-group">
      <label>Venue</label>
      <input type="text" name="venue" placeholder="Enter Venue" required/>
    </div>
    <div class="form-group">
      <label>Address</label>
      <input type="text" name="show_address" placeholder="Enter Address"/>
    </div>

    <!-- Time dropdowns -->
    <div class="form-group">
      <label>Start Time</label>
      <div style="display:flex;gap:8px;align-items:center;">
        <select id="start_hour" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Hour</option>
          <% for(let h=0;h<24;h++){ %>
            <option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
          <% } %>
        </select>
        <span style="font-size:18px;font-weight:600;">:</span>
        <select id="start_min" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Min</option>
          <option value="00">00</option><option value="15">15</option>
          <option value="30">30</option><option value="45">45</option>
        </select>
      </div>
      <input type="hidden" name="start_time" id="start_time"/>
    </div>

    <div class="form-group">
      <label>End Time</label>
      <div style="display:flex;gap:8px;align-items:center;">
        <select id="end_hour" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Hour</option>
          <% for(let h=0;h<24;h++){ %>
            <option value="<%= String(h).padStart(2,'0') %>"><%= String(h).padStart(2,'0') %></option>
          <% } %>
        </select>
        <span style="font-size:18px;font-weight:600;">:</span>
        <select id="end_min" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Min</option>
          <option value="00">00</option><option value="15">15</option>
          <option value="30">30</option><option value="45">45</option>
        </select>
      </div>
      <input type="hidden" name="end_time" id="end_time"/>
    </div>

    <p style="font-size:12px;color:#888;margin:20px 0 16px;letter-spacing:.4px;">COLLECTION FOR THIS SHOW</p>

    <div class="form-group">
      <label>Collection Name</label>
      <input type="text" name="collection_name" placeholder="Enter Collection Name" required/>
    </div>
    <div class="form-group">
      <label>Brand</label>
      <input type="text" name="brand" placeholder="Enter Brand"/>
    </div>
    <div class="form-group">
      <label>Season</label>
      <select name="season" style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Select Season</option>
        <option value="Spring">Spring</option>
        <option value="Summer">Summer</option>
        <option value="Fall">Fall</option>
        <option value="Winter">Winter</option>
      </select>
    </div>
    <div class="form-group">
      <label>Year</label>
      <select name="collection_year" style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Select Year</option>
        <% for(let y=1990;y<=2030;y++){ %><option value="<%= y %>"><%= y %></option><% } %>
      </select>
    </div>

    <div class="form-group">
      <label>Card Color</label>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <label class="color-choice">
          <input type="radio" name="card_color" value="#111111" checked/>
          <span class="color-swatch" style="background:#111111;"><span style="color:#fff;">Black</span></span>
        </label>
        <label class="color-choice">
          <input type="radio" name="card_color" value="#1B2A4A"/>
          <span class="color-swatch" style="background:#1B2A4A;"><span style="color:#fff;">Navy</span></span>
        </label>
        <label class="color-choice">
          <input type="radio" name="card_color" value="#6B6560"/>
          <span class="color-swatch" style="background:#6B6560;"><span style="color:#fff;">Stone</span></span>
        </label>
        <label class="color-choice">
          <input type="radio" name="card_color" value="#F5F0E8"/>
          <span class="color-swatch" style="background:#F5F0E8;border:1px solid #ddd;"><span style="color:#333;">Cream</span></span>
        </label>
      </div>
    </div>

    <button type="submit" class="btn btn-dark" style="width:100%;margin-top:8px;">+ Add Show</button>
  </form>
</div>

<script>
  // Populate show year dropdown from today's year onwards
  const today = new Date();
  const todayY = today.getFullYear();
  const todayM = today.getMonth() + 1; // 1-based
  const todayD = today.getDate();
  const yearSel = document.getElementById('sel_year');
  for (let y = todayY; y <= todayY + 6; y++) {
    const opt = document.createElement('option');
    opt.value = y; opt.textContent = y;
    yearSel.appendChild(opt);
  }

  document.getElementById('showForm').addEventListener('submit', function(e) {
    // Build show_date from dropdowns
    const m = document.getElementById('sel_month').value;
    const d = document.getElementById('sel_day').value;
    const y = document.getElementById('sel_year').value;

    if (!m || !d || !y) { e.preventDefault(); alert('Please select a full show date.'); return; }

    // Validate date is today or later
    const chosen = new Date(y, m - 1, d);
    const todayStart = new Date(todayY, today.getMonth(), todayD);
    if (chosen < todayStart) {
      e.preventDefault();
      alert('Show date must be today or a future date.');
      return;
    }
    document.getElementById('show_date').value = y + '-' + m + '-' + d;

    // Build start_time
    const sh = document.getElementById('start_hour').value;
    const sm = document.getElementById('start_min').value;
    if (sh && sm) document.getElementById('start_time').value = sh + ':' + sm;

    // Build end_time
    const eh = document.getElementById('end_hour').value;
    const em = document.getElementById('end_min').value;
    if (eh && em) document.getElementById('end_time').value = eh + ':' + em;
  });
</script>

</body></html>
