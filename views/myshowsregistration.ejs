<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">My Shows</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/myshowsregistration" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label>Show Logo</label>
      <div class="upload-row">
        <div class="upload-box">&#8593;</div>
        <input type="file" name="logo" accept="image/*"/>
      </div>
    </div>
    <div class="form-group">
      <label>Show Name</label>
      <input type="text" name="show_name" placeholder="Enter Show Name" required/>
    </div>
    <div class="form-group">
      <label>Show Date</label>
      <input type="date" name="show_date" required/>
    </div>
    <div class="form-group">
      <label>Venue</label>
      <input type="text" name="venue" placeholder="Enter Venue" required/>
    </div>
    <div class="form-group">
      <label>Address</label>
      <input type="text" name="show_address" placeholder="Enter Address"/>
    </div>
    <div class="form-group">
      <label>Collection ID <span style="font-size:12px;color:#888">(required)</span></label>
      <input type="number" name="collection_id" placeholder="Enter Collection ID" required/>
    </div>
    <div class="form-group">
      <label>Start Time</label>
      <input type="time" name="start_time"/>
    </div>
    <div class="form-group">
      <label>End Time</label>
      <input type="time" name="end_time"/>
    </div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add Show</button>
  </form>
</div>
</body></html>
