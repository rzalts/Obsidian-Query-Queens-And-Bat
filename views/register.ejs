<%- include('partials/head') %>
<div class="auth-page">
  <h1 class="auth-title">OBSIDIAN</h1>
  <%- include('partials/flash') %>
  <form class="form-container" action="/register" method="POST">
    <div class="form-group">
      <label>First Name</label>
      <input type="text" name="first_name" placeholder="Enter your First Name" required/>
    </div>
    <div class="form-group">
      <label>Last Name</label>
      <input type="text" name="last_name" placeholder="Enter your Last Name" required/>
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" placeholder="Enter your Email (e.g. name@example.com)"
             pattern="[^\s@]+@[^\s@]+\.[^\s@]+"
             title="Please enter a valid email address (e.g. name@example.com)"
             required/>
    </div>
    <div class="form-group">
      <label>Phone Number</label>
      <input type="tel" name="phone_number" placeholder="Enter your Phone Number"/>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="Enter your Password" required/>
    </div>
    <div class="form-group">
      <label>Role</label>
      <select name="role" required style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="coordinator" selected>Show Coordinator</option>
      </select>
    </div>
    <p class="form-link">Have an account? <a href="/login">Sign In</a></p>
    <button type="submit" class="btn btn-dark" style="width:100%">Sign Up</button>
  </form>
</div>
</body></html>
