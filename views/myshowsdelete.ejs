<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">Delete Show</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/myshowsdelete" method="POST">
    <div class="form-group">
      <label>Select Show to Delete</label>
      <select name="show_id" required>
        <option value="" disabled selected>Choose a show…</option>
        <% shows.forEach(s => { %>
          <option value="<%= s.show_id %>">
            <%= s.show_name %> — <%= s.show_date ? new Date(s.show_date).toLocaleDateString() : '' %>
          </option>
        <% }) %>
      </select>
    </div>
    <% if (!shows.length) { %>
      <p style="text-align:center;color:#888;font-size:14px;">No shows to delete.</p>
    <% } else { %>
      <button type="submit" class="btn btn-dark" style="width:100%;background:#c0392b;">- Delete Show</button>
    <% } %>
  </form>
</div>
</body></html>
