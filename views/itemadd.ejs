<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Item</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/itemadd" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Location ID</label><input type="number" name="location_id" placeholder="Enter Location ID" required/></div>
    <div class="form-group"><label>Collection ID</label><input type="number" name="collection_id" placeholder="Enter Collection ID" required/></div>
    <div class="form-group"><label>Category</label><input type="text" name="item_category" placeholder="Enter Category"/></div>
    <div class="form-group"><label>Size</label><input type="number" name="item_size" placeholder="Enter Size (number)"/></div>
    <div class="form-group"><label>Description</label><input type="text" name="item_description" placeholder="Enter Description"/></div>
    <div class="form-group"><label>Item Version</label><input type="number" name="item_version" placeholder="Enter Item Version"/></div>
    <div class="form-group"><label>Condition</label><input type="text" name="item_condition" placeholder="e.g. New / Good / Used"/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add Item</button>
  </form>
</div>
</body></html>
