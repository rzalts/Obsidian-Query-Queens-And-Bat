<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="table-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">Show Order</h2>
  <%- include('partials/flash') %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>Show Order ID</th><th>Show ID</th><th>Look ID</th><th>Sequence Number</th></tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr><td><%= o.show_order_id %></td><td><%= o.show_id %></td><td><%= o.look_id %></td><td><%= o.sequence_number %></td></tr>
        <% }) %>
        <% if (!orders.length) { %><tr><td colspan="4" style="text-align:center;color:#888">No show order entries.</td></tr><% } %>
      </tbody>
    </table>
  </div>
  <div class="btn-group">
    <a href="/showorderadd<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">+ Add to Show Order</a>
    <a href="/showorderdelete<%= show_id ? `?show_id=${show_id}` : '' %>" class="btn btn-dark">- Delete from Show Order</a>
    <% if (show_id) { %><a href="/mymenudetail/<%= show_id %>" class="btn btn-outline">&#8592; Back</a><% } %>
  </div>
</div>
</body></html>
