<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">Add Fitting</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/fittingadd" method="POST" id="fittingForm">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group">
      <label>Look</label>
      <select name="look_id" required style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Choose a look…</option>
        <% looks.forEach(l => { %>
          <option value="<%= l.look_id %>">#<%= l.look_id %> — <%= l.look_category || 'No category' %><%= l.look_description ? ' · ' + l.look_description.substring(0,40) : '' %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label>Fitting Date</label>
      <div style="display:flex;gap:8px;">
        <select id="fit_month" style="flex:2;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Month</option>
          <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((mn,i) => { const v=String(i+1).padStart(2,'0'); %>
            <option value="<%= v %>"><%= mn %></option>
          <% }); %>
        </select>
        <select id="fit_day" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Day</option>
          <% for(let d=1;d<=31;d++){ %><option value="<%= String(d).padStart(2,'0') %>"><%= d %></option><% } %>
        </select>
        <select id="fit_year" style="flex:1;padding:12px 10px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
          <option value="" disabled selected>Year</option>
        </select>
      </div>
      <input type="hidden" name="fitting_date" id="fitting_date"/>
    </div>

    <div class="form-group">
      <label>Status</label>
      <select name="fitting_status" style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Select Status</option>
        <option value="Scheduled">Scheduled</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
        <option value="No Show">No Show</option>
      </select>
    </div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add New Fitting</button>
  </form>
</div>
<script>
  const today = new Date();
  const yearSel = document.getElementById('fit_year');
  for (let y = today.getFullYear(); y <= today.getFullYear() + 6; y++) {
    const opt = document.createElement('option'); opt.value = y; opt.textContent = y;
    yearSel.appendChild(opt);
  }
  document.getElementById('fittingForm').addEventListener('submit', function() {
    const m = document.getElementById('fit_month').value;
    const d = document.getElementById('fit_day').value;
    const y = document.getElementById('fit_year').value;
    if (m && d && y) document.getElementById('fitting_date').value = y + '-' + m + '-' + d;
  });
</script>
</body></html>
