<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">Delete Collection</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/collectiondelete" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group">
      <label>Select Collection to Delete</label>
      <select name="collection_id" required style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Choose a collection…</option>
        <% collections.forEach(c => { %>
          <option value="<%= c.collection_id %>">#<%= c.collection_id %> — <%= c.collection_name %></option>
        <% }) %>
      </select>
    </div>
    <% if (!collections.length) { %>
      <p style="text-align:center;color:#888;font-size:14px;">No collections available to delete.</p>
    <% } else { %>
      <button type="submit" class="btn btn-dark" style="width:100%;background:#c0392b;">- Delete Collection</button>
    <% } %>
  </form>
</div>
</body></html>
