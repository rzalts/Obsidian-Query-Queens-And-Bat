<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <a href="<%= user && user.role === 'developer' ? '/admin' : '/myshows' %>" style="text-decoration:none;color:inherit;display:block;"><h1 class="page-title">OBSIDIAN</h1></a>
  <h2 class="page-subtitle">Change Alteration Status</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/alterationstatus" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group">
      <label>Alteration</label>
      <select name="alteration_id" required style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Choose an alteration…</option>
        <% alterations.forEach(a => { %>
          <option value="<%= a.alteration_id %>">#<%= a.alteration_id %> — <%= a.date_needed_by ? new Date(a.date_needed_by).toLocaleDateString() : 'No date' %> (<%= a.alteration_status %>)</option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>New Status</label>
      <select name="new_status" required style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:10px;font-size:14px;background:#fff;">
        <option value="" disabled selected>Select Status</option>
        <option value="Pending">Pending</option>
        <option value="In Progress">In Progress</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
      </select>
    </div>
    <button type="submit" class="btn btn-dark" style="width:100%">Change Status</button>
  </form>
</div>
</body></html>
