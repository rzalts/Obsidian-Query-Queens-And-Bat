<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Alteration</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/alterationstatus" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Alteration ID</label><input type="number" name="alteration_id" placeholder="Enter Alteration ID" required/></div>
    <div class="form-group"><label>New Status</label><input type="text" name="new_status" placeholder="e.g. Pending / Completed" required/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">Change Status</button>
  </form>
</div>
</body></html>
