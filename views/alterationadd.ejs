<%- include('partials/head') %>
<%- include('partials/nav') %>
<div class="shows-page">
  <h1 class="page-title">OBSIDIAN</h1>
  <h2 class="page-subtitle">Alteration</h2>
  <%- include('partials/flash') %>
  <form class="form-container" action="/alterationadd" method="POST">
    <input type="hidden" name="show_id" value="<%= show_id || '' %>"/>
    <div class="form-group"><label>Item ID</label><input type="number" name="item_id" placeholder="Enter Item ID" required/></div>
    <div class="form-group"><label>Fitting ID</label><input type="number" name="fitting_id" placeholder="Enter Fitting ID" required/></div>
    <div class="form-group"><label>Alteration Type</label><input type="text" name="alteration_type" placeholder="Enter Alteration Type" required/></div>
    <div class="form-group"><label>Date Needed By</label><input type="date" name="date_needed_by"/></div>
    <div class="form-group"><label>Status</label><input type="text" name="alteration_status" placeholder="e.g. Pending / Completed"/></div>
    <button type="submit" class="btn btn-dark" style="width:100%">+ Add New Alteration</button>
  </form>
</div>
<img class="page-wm" src="https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?w=500&q=60" alt=""/>
</body></html>
