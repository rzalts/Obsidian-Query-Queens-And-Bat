<%- include('partials/head') %>
<div class="auth-page">
  <h1 class="auth-title">Forgot Password?</h1>
  <p class="auth-subtitle">OBSIDIAN - Show Coordinator</p>
  <%- include('partials/flash') %>
  <form class="form-container" action="/passwordreset" method="POST">
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" placeholder="Enter your Email" required/>
      <p style="font-size:12px;color:#777;margin-top:4px">Enter your registered email to reset your password.</p>
    </div>
    <div class="form-group">
      <label>New Password</label>
      <input type="password" name="new_password" placeholder="Enter New Password" required/>
    </div>
    <button type="submit" class="btn btn-dark" style="width:100%">Reset Password</button>
    <p class="form-link" style="margin-top:14px"><a href="/login">Back to Login</a></p>
  </form>
</div>
</body></html>
